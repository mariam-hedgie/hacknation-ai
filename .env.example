# Copy this file to .env and replace only the TODO values locally.
# Never commit real API keys. Do not expose them in browser/client code.

# TODO: Create at https://app.tavily.com.
TAVILY_API_KEY=TODO_TAVILY_API_KEY

# TODO: Create at https://elevenlabs.io/app/settings/api-keys.
ELEVENLABS_API_KEY=TODO_ELEVENLABS_API_KEY
AVEN_VOICE_ENABLED=false

# Optional local NLP. Ollama runs on the server, never in the browser. Start it
# locally with `ollama serve`, then pull the configured model once.
AVEN_NLP_PROVIDER=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma3:4b

# TODO: Lovable normally connects through its own project integrations. Only set
# this if Lovable explicitly gives this project a server-side API key.
LOVABLE_API_KEY=TODO_IF_REQUIRED

# Recommended live maps mode. Restrict this key by API, referrer/IP, quota,
# and budget in Google Cloud before use.
GOOGLE_MAPS_API_KEY=TODO_GOOGLE_MAPS_API_KEY

# Free road-routing fallback (walking, cycling, and driving only).
OPENROUTESERVICE_API_KEY=TODO_OPENROUTESERVICE_API_KEY

# Databricks Apps should normally inject service-principal credentials and
# resource values. These two non-secret connection identifiers support local
# integration testing; never commit a personal access token.
DATABRICKS_SERVER_HOSTNAME=TODO_DATABRICKS_SERVER_HOSTNAME
DATABRICKS_HTTP_PATH=TODO_DATABRICKS_HTTP_PATH

# Replace only after the Databricks team returns the final governed table names.
AVEN_FACILITY_TABLE=TODO_CATALOG.SCHEMA.FACILITY_EVIDENCE
AVEN_SAVED_PLAN_TABLE=TODO_CATALOG.SCHEMA.SAVED_PLAN
AVEN_FEEDBACK_TABLE=TODO_CATALOG.SCHEMA.PLAN_FEEDBACK

# Local-only identity. The deployed Databricks App must override this with
# AVEN_AUTH_MODE=databricks and must receive AVEN_IDENTITY_PEPPER through a
# Databricks secret resource, never from a committed file.
AVEN_AUTH_MODE=local_demo
AVEN_ALLOW_LOCAL_DEMO=true

# Databricks Apps inject these from the attached Lakebase Autoscaling resource.
# They are listed only to document the server contract; do not fill them for the
# ordinary local demo and never commit a database password.
ENDPOINT_NAME=TODO_LAKEBASE_ENDPOINT_NAME
PGHOST=TODO_LAKEBASE_HOST
PGDATABASE=TODO_LAKEBASE_DATABASE
PGUSER=TODO_LAKEBASE_USER
PGPORT=5432
PGSSLMODE=require
